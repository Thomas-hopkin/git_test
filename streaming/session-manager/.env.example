# Session manager configuration. Copy to .env if running outside Docker.
# When run via docker-compose, these are set in docker-compose.yml instead.

# The session manager's own HTTP port
PORT=5000

# neko-rooms API (the streaming container manager)
NEKO_ROOMS_URL=http://localhost:3000
# Optional auth header for the neko-rooms API, e.g. "Bearer xxxxx".
# Leave empty if neko-rooms has no API auth (default in our compose setup).
NEKO_ROOMS_AUTH=

# The game-client Docker image neko-rooms should launch per session
NEKO_IMAGE=runepvp-client:latest

# Game server address, injected into each streaming container.
# Must be reachable from inside a container — use the VPS public IP, not 127.0.0.1.
GAME_HOST=127.0.0.1
GAME_PORT=43594

# Capacity: the hard cap on simultaneous game containers. Tune to your VPS.
# Rule of thumb: ~1.5 vCPU and ~1.5GB RAM per session. A 4 vCPU / 8GB box ≈ 3-4.
MAX_SESSIONS=4

# How many spare containers to keep pre-warmed so launches are instant.
# Pool never pushes total containers above MAX_SESSIONS.
POOL_SIZE=1

# Reap an active session if it hasn't sent a heartbeat in this long (ms).
# The browser heartbeats every 20s, so 60s = 3 missed beats = player left.
HEARTBEAT_TIMEOUT_MS=60000

# Hard cap on any single session's lifetime (ms). Default 2 hours.
SESSION_MAX_LIFETIME_MS=7200000

# Drop a queued player if their browser stops polling for this long (ms).
QUEUE_STALE_MS=15000

# How often the reaper sweeps for dead sessions / stale queue entries (ms).
REAPER_INTERVAL_MS=10000
