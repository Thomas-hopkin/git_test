# Public IP of your VPS (required for WebRTC to work through NAT)
VPS_IP=1.2.3.4

# RSMod game server address as seen FROM INSIDE a streaming container.
# Use the VPS public IP, NOT 127.0.0.1 — containers can't reach the host via localhost.
GAME_HOST=1.2.3.4
GAME_PORT=43594

# Password for the neko admin panel
NEKO_ADMIN_PASSWORD=changeme

# Capacity tuning for the session manager.
# MAX_SESSIONS = hard cap on simultaneous players (~1.5 vCPU + 1.5GB RAM each).
# POOL_SIZE    = spare containers kept pre-warmed for instant launches.
MAX_SESSIONS=4
POOL_SIZE=1
