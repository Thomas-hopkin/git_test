# Copy this file to .env.local and fill in your values.

# LostCity game server REST API — for leaderboard data (no trailing slash).
GAME_API_URL=http://YOUR_VPS_IP:8080

# LostCity game client URL — the address players open to play in their browser.
# This is the root of your VPS running the 2004Scape Engine-TS server.
# Must be accessible from the player's browser, so use the public VPS IP.
# Prefix with NEXT_PUBLIC_ so Next.js exposes it to the browser bundle.
NEXT_PUBLIC_GAME_CLIENT_URL=http://YOUR_VPS_IP

# Tokenomics dashboard (same VPS, port 4000) — for the public /tokenomics page
TOKENOMICS_URL=http://YOUR_VPS_IP:4000
