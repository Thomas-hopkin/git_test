# Copy this file to .env.local and fill in your values.
# The game server REST API base URL (no trailing slash).
GAME_API_URL=http://YOUR_VPS_IP:8080

# Session manager — the production front-end to the streaming stack (port 5000).
# This is what the /play page talks to: it handles the warm pool, the queue,
# heartbeats and teardown. Point it at your VPS.
SESSION_MANAGER_URL=http://YOUR_VPS_IP:5000

# neko-rooms streaming service (same VPS, port 3000). Only needed if you call
# neko-rooms directly; normally everything goes through the session manager.
NEKO_ROOMS_URL=http://YOUR_VPS_IP:3000
NEKO_IMAGE=runepvp-client:latest
NEKO_ADMIN_PASSWORD=changeme

# Address of the game server as seen FROM INSIDE a Docker container on the VPS.
# This must be the VPS public IP (not 127.0.0.1) so containers can reach the host.
GAME_HOST=YOUR_VPS_IP
GAME_PORT=43594

# Tokenomics dashboard (same VPS, port 4000) — for the public /tokenomics page
TOKENOMICS_URL=http://YOUR_VPS_IP:4000
