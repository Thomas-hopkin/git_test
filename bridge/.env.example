# Copy this to .env and fill in your values

# Solana RPC — use devnet for testing, mainnet-beta for production
# Free RPC options: https://helius.dev (recommended), https://quicknode.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# Your SPL token mint address (from when you created the token on pump.fun or CLI)
TOKEN_MINT_ADDRESS=

# Base58 private key of the server's hot wallet (holds tokens to send to players)
# Generate with: solana-keygen new --outfile server-wallet.json
# Get base58 with: cat server-wallet.json | python3 -c "import json,sys,base58; print(base58.b58encode(bytes(json.load(sys.stdin))).decode())"
SERVER_PRIVATE_KEY=

# Secret key shared between bridge and game server
BRIDGE_API_KEY=changeme-replace-this

# Port for the bridge API
BRIDGE_PORT=4567
